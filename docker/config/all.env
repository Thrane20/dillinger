TZ="Australia/Brisbane"
PUID=1000
PGID=1000
LIBVA_DRIVERS_PATH=/usr/lib/x86_64-linux-gnu/dri/
LIBVA_DRIVER_NAME=i965
DOCKER_RUNTIME=nvidia
SHARED_IPC=host
UDEVD_NETWORK=host
SHM_SIZE=500M
DBUS=/run/dbus
LOCAL_STATE=/home/retro

# NVIDIA
NVIDIA_VISIBLE_DEVICES=${GPU_UUID}
NVIDIA_DRIVER_CAPABILITIES=all
GPU_UUID=all

# Xorg
XORG_SOCKET=/tmp/.X11-unix
XORG_DISPLAY=:0

PULSE_SERVER=unix:/tmp/pulse/native
PULSE_SOCKET_HOST=/run/user/1000/pulse
PULSE_SOCKET_GUEST=/tmp/pulse/

BUILD_BASE_IMAGE=dillinger/gow-base:latest
BUILD_BASE_APP_IMAGE=dillinger/gow-base-app:latest
DOCKER_PREFIX=dillinger
DOCKER_VOLUME=dillinger
NAME_WINE_RUNNER=winerunner
VERSION_WINE_RUNNER=1.0