PUID=${PUID:-1000}
PGID=${PGID:-1000}

DOCKER_PREFIX=dillinger
DOCKER_VOLUME=dillinger

NAME_BASE=$(DOCKER_PREFIX)/base
VERSION_BASE=1.0

# Builders
NAME_BUILDER=${DOCKER_PREFIX}/builder
VERSION_BUILDER=1.0

NAME_OPENTRACK=${DOCKER_PREFIX}/opentrack
VERSION_OPENTRACK=1.0

# Runners
NAME_RUNNER_BASE=${DOCKER_PREFIX}/runner-base
VERSION_RUNNER_BASE=1.0
DBUS=/run/dbus
SHM_SIZE=500M
PULSE_SOCKET_GUEST=/tmp/pulse/
PULSE_SERVER=unix:/tmp/pulse/native
PULSE_SOCKET_HOST=/run/user/1000/pulse
SHARED_IPC=host
XORG_SOCKET=/tmp/.X11-unix
XORG_DISPLAY=:0
UDEVD_NETWORK=host

NAME_RUNNER_WINE=${DOCKER_PREFIX}/runner-wine
VERSION_RUNNER_WINE=1.0

NAME_CORE=${DOCKER_PREFIX}/core
VERSION_CORE=1.0

NAME_WINE_RUNNER=runner-wine
VERSION_WINE_RUNNER=1.0

